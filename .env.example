# ============================================================
# Application Configuration
# ============================================================
# Replace with your target application's URL.
BASE_URL=https://staging.example-app.com/

# ============================================================
# E2E Test Configuration
# ============================================================
DEFAULT_BRAND=ExampleBrand
DEFAULT_USER=admin_user

# ============================================================
# App Users
# ============================================================
# Add users for each role your application supports.
ADMIN_USER=admin@example-app.com
ADMIN_PASS=YourSecurePassword!

ANALYST_USER=analyst@example-app.com
ANALYST_PASS=YourSecurePassword!

APPROVER_USER=approver@example-app.com
APPROVER_PASS=YourSecurePassword!

REVIEWER_USER=reviewer@example-app.com
REVIEWER_PASS=YourSecurePassword!

# ============================================================
# Database (optional — if tests require direct DB access)
# ============================================================
# DB_HOST=your-database-host.example.com
# DB_PORT=5432
# DB_USER=your_db_user
# DB_PASS=your_db_password
# DB_NAME=your_db_name
